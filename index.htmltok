<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TikTok Feed</title>

<style>
body{
    margin:0;
    background:#000;
    font-family:sans-serif;
}

.feed{
    height:100vh;
    width:100%;
    overflow-y:scroll;
    scroll-snap-type:y mandatory;
}

.video{
    height:100vh;
    width:100%;
    scroll-snap-align:start;
    display:flex;
    justify-content:center;
    align-items:center;
}

.video iframe{
    width:100%;
    height:100%;
    border:none;
}
</style>
</head>

<body>

<div class="feed">

<div class="video">
<iframe src="https://www.tiktok.com/embed/7291234567890123456"></iframe>
</div>

<div class="video">
<iframe src="https://www.tiktok.com/embed/7299876543210987654"></iframe>
</div>

<div class="video">
<iframe src="https://www.tiktok.com/embed/7281234567890987654"></iframe>
</div>

</div>

</body>
</html>